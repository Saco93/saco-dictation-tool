# Provider selection: whisper_local, whisper_server, or openrouter
STTD_PROVIDER_KIND=whisper_local
# For whisper_server (persistent local inference), point to your server:
# STTD_PROVIDER_BASE_URL=http://127.0.0.1:8080

# Local whisper defaults
STTD_WHISPER_CMD=whisper-cli
STTD_WHISPER_MODEL_PATH=/usr/share/whisper.cpp/models/ggml-small.en-q5_1.bin
# STTD_WHISPER_THREADS=16
# STTD_WHISPER_BEAM_SIZE=1
# STTD_WHISPER_BEST_OF=1
# STTD_WHISPER_NO_FALLBACK=true
# STTD_WHISPER_NO_TIMESTAMPS=true

# OpenRouter API token (required only when STTD_PROVIDER_KIND=openrouter)
# STTD_OPENROUTER_API_KEY=sk-or-your-token

# Optional overrides
# STTD_OPENROUTER_MODEL=openai/whisper-1
# STTD_OPENROUTER_LANGUAGE=en
# STTD_INPUT_DEVICE=alsa_input.pci-0000_00_1f.3.analog-stereo
# STTD_MONTHLY_SOFT_SPEND_LIMIT_USD=20.0
# STTD_ESTIMATED_REQUEST_COST_USD=0.01
