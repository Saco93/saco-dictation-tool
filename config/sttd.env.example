# Canonical hosted-provider overrides.
# Precedence is:
# runtime canonical > runtime legacy > env-file canonical > env-file legacy > TOML canonical > TOML legacy

# Preferred secret source for DashScope or other hosted OpenAI-compatible providers.
# STTD_PROVIDER_API_KEY=sk-your-hosted-provider-key

# Optional canonical hosted overrides.
# STTD_PROVIDER_KIND=openai_compatible
# STTD_PROVIDER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# STTD_PROVIDER_MODEL=qwen3-asr-flash
# Leave blank or omit to use provider auto-detect.
# STTD_PROVIDER_LANGUAGE=
# Comma-separated bilingual hints for hosted chat-completions benchmarking.
# STTD_PROVIDER_LANGUAGE_HINTS=zh,en
# STTD_PROVIDER_REQUEST_MODE=chat_completions

# Deprecated OpenRouter aliases remain supported for compatibility only.
# STTD_OPENROUTER_API_KEY=sk-or-your-token
# STTD_OPENROUTER_MODEL=openai/whisper-1
# STTD_OPENROUTER_LANGUAGE=en

# Local whisper overrides.
# STTD_WHISPER_CMD=whisper-cli
# STTD_WHISPER_MODEL_PATH=/usr/share/whisper.cpp/models/ggml-small.en-q5_1.bin
# STTD_WHISPER_THREADS=16
# STTD_WHISPER_BEAM_SIZE=1
# STTD_WHISPER_BEST_OF=1
# STTD_WHISPER_NO_FALLBACK=true
# STTD_WHISPER_NO_TIMESTAMPS=true

# Other optional overrides.
# STTD_INPUT_DEVICE=alsa_input.pci-0000_00_1f.3.analog-stereo
# STTD_PLAYBACK_ENABLED=true
# STTD_PLAYERCTL_CMD=playerctl
# STTD_PLAYBACK_COMMAND_TIMEOUT_MS=400
# STTD_PLAYBACK_AGGREGATE_TIMEOUT_MS=1200
# STTD_MONTHLY_SOFT_SPEND_LIMIT_USD=20.0
# STTD_ESTIMATED_REQUEST_COST_USD=0.01
